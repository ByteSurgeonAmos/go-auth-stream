    {
      "name": "Company Management",
      "item": [
        {
          "name": "Update Company",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"company\": {\n    \"company_name\": \"{{company_name}}\",\n    \"link\": \"https://example.com\",\n    \"socials\": []\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/signup-process/updateCompany",
              "host": ["{{base_url}}"],
              "path": ["api", "signup-process", "updateCompany"]
            },
            "description": "Add or update company information for a user"
          }
        }
      ]
    },
    {
      "name": "Social Media Platforms",
      "item": [
        {
          "name": "Get All Platforms",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/social/platforms",
              "host": ["{{base_url}}"],
              "path": ["api", "social", "platforms"]
            },
            "description": "Get list of all supported social media platforms"
          }
        },
        {
          "name": "Link Social Platform",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_name\": \"{{company_name}}\",\n  \"social\": {\n    \"platform\": \"x\",\n    \"username\": \"myhandle\",\n    \"url\": \"https://twitter.com/myhandle\",\n    \"access_token\": \"your_access_token\",\n    \"refresh_token\": \"your_refresh_token\",\n    \"expires_at\": \"2024-12-31T23:59:59Z\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/social/platforms",
              "host": ["{{base_url}}"],
              "path": ["api", "social", "platforms"]
            },
            "description": "Link a social media platform to a company"
          }
        },
        {
          "name": "Get User Social Platforms",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/social/user/platforms",
              "host": ["{{base_url}}"],
              "path": ["api", "social", "user", "platforms"]
            },
            "description": "Get all social platforms linked to user's companies"
          }
        },
        {
          "name": "Get User Social Platforms By Company",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/social/user/platforms?company_name={{company_name}}",
              "host": ["{{base_url}}"],
              "path": ["api", "social", "user", "platforms"],
              "query": [
                {
                  "key": "company_name",
                  "value": "{{company_name}}"
                }
              ]
            },
            "description": "Get social platforms for a specific company"
          }
        }
      ]
    },
