{
  "info": {
    "_postman_id": "agent4-social-media-api",
    "name": "Agent4 Social Media API",
    "description": "Complete API collection for Agent4 Social Media Management Platform with Twitter, Facebook, and Instagram integration. Includes role-based authentication (User/Admin).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "agent4-api"
  },
  "auth": {
    "type": "bearer",
