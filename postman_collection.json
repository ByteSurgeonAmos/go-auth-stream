            "body": {
              "mode": "raw",
              "raw": "{\n  \"post_id\": \"{{post_id}}\",\n  \"company_name\": \"{{company_name}}\",\n  \"platforms\": [\"instagram\"],\n  \"image_url\": \"https://example.com/image.jpg\"\n}"
